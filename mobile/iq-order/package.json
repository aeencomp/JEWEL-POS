{
  "name": "iq-order-mobile",
  "version": "1.0.0",
  "private": true,
  "description": "IQ Order — Android app (Capacitor wrapper for https://iq-pos.com/app)",
  "scripts": {
    "sync": "cap sync android",
    "open": "cap open android",
    "build:debug": "node scripts/build-android.mjs debug",
    "build:release": "node scripts/build-android.mjs release",
    "icons": "node scripts/generate-icons.mjs",
    "assets": "npm run icons && npx @capacitor/assets generate --android"
  },
  "dependencies": {
    "@capacitor/android": "^8.0.0",
    "@capacitor/core": "^8.0.0",
    "@capacitor/splash-screen": "^8.0.0",
    "@capacitor/status-bar": "^8.0.0"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^8.0.0",
    "sharp": "^0.34.2"
  }
}
